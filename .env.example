# Discord
DISCORD_BOT_TOKEN=

# DeepSeek
DEEPSEEK_API_KEY=

# Gemini (opcional — para embeddings RAG)
# Google Gemini oferece embeddings gratuitos via API key
# Obtenha em: https://ai.google.dev/
# Recomendado para RAG (free-tier generoso)
GEMINI_API_KEY=

# OpenAI (opcional — para embeddings RAG alternativos)
# Pode ser usado em vez do Gemini se preferir
OPENAI_API_KEY=

# Supabase PostgreSQL / Self-hosted (optional — enables persistent session storage + RAG)
# Format: postgresql://postgres:[PASSWORD]@host:5432/postgres
# O RAG jurídico atual usa o schema `juridico` (ex.: juridico.chunks / juridico.match_chunks)
# Leave empty to use in-memory storage (sessions lost on bot restart)
SUPABASE_DB_URL=

# Bot config (optional — defaults in config.py)
# TARGET_GUILD_ID=1283924742851661844
# TARGET_CHANNEL_ID=1486301006659715143
# MODEL_ID=deepseek-chat
# HISTORY_RUNS=5
